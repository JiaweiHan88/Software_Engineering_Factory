# BMAD Copilot Factory — Environment Variables
# Copy to .env and fill in values

# ─── Paperclip ───────────────────────────────────────
PAPERCLIP_ENABLED=true
PAPERCLIP_URL=http://localhost:3100
PAPERCLIP_AGENT_API_KEY=
PAPERCLIP_COMPANY_ID=bmad-factory
PAPERCLIP_MODE=inbox-polling
PAPERCLIP_INBOX_CHECK_INTERVAL_MS=15000
PAPERCLIP_WEBHOOK_PORT=3200
PAPERCLIP_TIMEOUT_MS=10000

# ─── Target Workspace ───────────────────────────────
# Separate workspace for agents to operate in (prevents exploring factory source)
TARGET_PROJECT_ROOT=../bmad-target-project

# ─── Copilot CLI ─────────────────────────────────────
# Optional: override default model (default: claude-sonnet-4.5)
COPILOT_MODEL=
# Optional: headless mode port (default: 4321)
COPILOT_PORT=4321

# ─── BYOK (Bring Your Own Keys) ─────────────────────
# Optional: only needed if using BYOK mode
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# ─── Database (for Paperclip) ───────────────────────
POSTGRES_USER=paperclip
POSTGRES_PASSWORD=paperclip_dev
POSTGRES_DB=paperclip

# ─── Agent Settings ─────────────────────────────────
# Max concurrent Copilot sessions
MAX_CONCURRENT_AGENTS=2
# Inbox check interval — only used in inbox-polling mode (ms)
PAPERCLIP_INBOX_CHECK_INTERVAL_MS=15000
# Max code review passes before escalation
REVIEW_PASS_LIMIT=3
