{
  "name": "bmad-copilot-factory",
  "version": "0.1.0",
  "description": "Autonomous Software Building Factory — Paperclip + Copilot SDK + BMAD Method",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "TARGET_PROJECT_ROOT=../bmad-target-project tsx src/index.ts",
    "start:status": "tsx src/index.ts --status",
    "start:dry-run": "tsx src/index.ts --dry-run",
    "start:paperclip": "PAPERCLIP_ENABLED=true TARGET_PROJECT_ROOT=../bmad-target-project tsx src/index.ts --paperclip",
    "test": "vitest run",
    "test:watch": "vitest",
    "sandbox:hello": "tsx src/sandbox/hello-copilot.ts",
    "sandbox:agent": "tsx src/sandbox/test-agent.ts",
    "sandbox:tools": "tsx src/sandbox/test-tools.ts",
    "sandbox:orchestrator": "tsx src/sandbox/test-orchestrator.ts",
    "mcp:sprint": "tsx src/mcp/bmad-sprint-server/index.ts",
    "observability:up": "docker compose -f docker-compose.observability.yml up -d",
    "observability:down": "docker compose -f docker-compose.observability.yml down",
    "observability:logs": "docker compose -f docker-compose.observability.yml logs -f",
    "start:otel": "OTEL_ENABLED=true OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318 TARGET_PROJECT_ROOT=../bmad-target-project tsx src/index.ts",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "e2e:smoke": "tsx scripts/e2e-smoke.ts",
    "e2e:smoke:ceo": "tsx scripts/e2e-smoke.ts --ceo-only --skip-cleanup --verbose",
    "e2e:smoke:verbose": "tsx scripts/e2e-smoke.ts --skip-cleanup --verbose"
  },
  "dependencies": {
    "@github/copilot-sdk": "^0.1.32",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/exporter-metrics-otlp-http": "^0.57.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.57.0",
    "@opentelemetry/resources": "^1.30.0",
    "@opentelemetry/sdk-metrics": "^1.30.0",
    "@opentelemetry/sdk-trace-base": "^1.30.0",
    "@opentelemetry/sdk-trace-node": "^1.30.0",
    "@opentelemetry/semantic-conventions": "^1.28.0",
    "dotenv": "^17.3.1",
    "js-yaml": "^4.1.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.0.0",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "eslint": "^9.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.57.1",
    "vitest": "^3.0.0"
  },
  "license": "MIT"
}
