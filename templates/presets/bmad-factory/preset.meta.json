{
  "name": "bmad-factory",

 *  "displayName": "BMAD Copilot Factory",

 * The main Paperclip ↔ BMAD integration engine. Polls Paperclip for  "description": "Autonomous software building company using BMAD methodology with Copilot SDK agents",

 * heartbeats, dispatches work to BMAD agents, and reports results back.  "version": "0.2.0",

 *  "author": "BMAD Copilot Factory",

 * This is the Paperclip-mode alternative to the standalone SprintRunner.  "roles": [

 * Instead of reading sprint-status.yaml directly, it takes work assignments    {

 * from Paperclip's org chart scheduler.      "name": "ceo",

 *      "template": "../../roles/bmad-ceo/role.json",

 * Lifecycle:      "required": true,

 * 1. Register all BMAD agents with Paperclip      "paperclipAgent": "bmad-ceo"

 * 2. Enter poll loop:    },

 *    a. Poll Paperclip for heartbeats (assigned work)    {

 *    b. For each heartbeat, dispatch to the appropriate BMAD agent      "name": "product-manager",

 *    c. Report results back to Paperclip      "template": "../../roles/bmad-product-manager/role.json",

 *    d. Sleep for the suggested interval      "required": true,

 * 3. On shutdown, deregister agents and clean up sessions      "paperclipAgent": "bmad-pm"

 *    },

 * @module adapter/paperclip-loop    {

 */      "name": "architect",

      "template": "../../roles/bmad-architect/role.json",

import type { BmadConfig } from "../config/config.js";      "required": true,

import type { AgentDispatcher } from "./agent-dispatcher.js";      "paperclipAgent": "bmad-architect"

import type { SessionManager } from "./session-manager.js";    },

import { PaperclipClient } from "./paperclip-client.js";    {

import type { PaperclipHeartbeat } from "./paperclip-client.js";      "name": "product-owner",

import { PaperclipReporter } from "./reporter.js";      "template": "../../roles/bmad-product-owner/role.json",

import { handlePaperclipHeartbeat } from "./heartbeat-handler.js";      "required": true,

import type { HeartbeatResult } from "./heartbeat-handler.js";      "paperclipAgent": "bmad-po"

import { allAgents } from "../agents/registry.js";    },

    {

// ─────────────────────────────────────────────────────────────────────────────      "name": "developer",

// Events      "template": "../../roles/bmad-developer/role.json",

// ─────────────────────────────────────────────────────────────────────────────      "required": true,

      "paperclipAgent": "bmad-dev"

/** Paperclip loop lifecycle events. */    },

export type PaperclipLoopEvent =    {

  | { type: "loop-start"; agentCount: number }      "name": "code-reviewer",

  | { type: "poll"; heartbeatCount: number }      "template": "../../roles/bmad-code-reviewer/role.json",

  | { type: "heartbeat-processed"; agentId: string; ticketId?: string; result: HeartbeatResult }      "required": true,

  | { type: "heartbeat-error"; agentId: string; error: string }      "paperclipAgent": "bmad-qa"

  | { type: "poll-error"; error: string }    },

  | { type: "loop-stop"; reason: string }    {

  | { type: "agents-registered"; count: number };      "name": "scrum-master",

      "template": null,

export type PaperclipLoopEventHandler = (event: PaperclipLoopEvent) => void;      "required": false,

      "paperclipAgent": "bmad-sm"

// ─────────────────────────────────────────────────────────────────────────────    },

// Options    {

// ─────────────────────────────────────────────────────────────────────────────      "name": "analyst",

      "template": null,

/** Options for running the Paperclip integration loop. */      "required": false,

export interface PaperclipLoopOptions {      "paperclipAgent": "bmad-analyst"

  /** Event callback for lifecycle events */    },

  onEvent?: PaperclipLoopEventHandler;    {

  /** Streaming callback for agent output */      "name": "ux-designer",

  onDelta?: (delta: string) => void;      "template": null,

  /** Override poll interval (defaults to config.paperclip.pollIntervalMs) */      "required": false,

  pollIntervalMs?: number;      "paperclipAgent": "bmad-ux-designer"

  /** Maximum number of poll cycles before stopping (undefined = infinite) */    },

  maxCycles?: number;    {

  /** Whether to register agents on startup (default: true) */      "name": "tech-writer",

  registerAgents?: boolean;      "template": null,

}      "required": false,

      "paperclipAgent": "bmad-tech-writer"

// ─────────────────────────────────────────────────────────────────────────────    }

// Paperclip Loop  ],

// ─────────────────────────────────────────────────────────────────────────────  "orgChart": {

    "description": "BMAD Factory org chart — Paperclip governance structure",

/**    "root": "bmad-ceo",

 * PaperclipLoop drives the BMAD factory via Paperclip's heartbeat mechanism.    "hierarchy": {

 *      "bmad-ceo": {

 * Usage:        "reports": ["bmad-pm", "bmad-architect"],

 * ```ts        "goals": ["Define product vision", "Approve architecture decisions"]

 * const loop = new PaperclipLoop(sessionManager, dispatcher, config);      },

 * await loop.start({      "bmad-pm": {

 *   onEvent: (e) => console.log(e),        "reports": ["bmad-dev", "bmad-sm"],

 * });        "goals": ["Write PRDs", "Define user stories", "Prioritize backlog"]

 * // ... runs until stopped or maxCycles reached      },

 * await loop.stop();      "bmad-architect": {

 * ```        "reports": ["bmad-qa"],

 */        "goals": ["Design system architecture", "Tech stack decisions", "Data models"]

export class PaperclipLoop {      },

  private sessionManager: SessionManager;      "bmad-dev": {

  private dispatcher: AgentDispatcher;        "reports": [],

  private config: BmadConfig;        "goals": ["Implement stories", "Write code and tests"]

  private client: PaperclipClient;      },

  private reporter: PaperclipReporter;      "bmad-qa": {

  private running = false;        "reports": [],

  private abortController: AbortController | null = null;        "goals": ["Adversarial code review", "Quality gates enforcement"]

      },

  constructor(      "bmad-sm": {

    sessionManager: SessionManager,        "reports": [],

    dispatcher: AgentDispatcher,        "goals": ["Sprint planning", "Sprint status tracking", "Impediment removal"]

    config: BmadConfig,      }

  ) {    }

    this.sessionManager = sessionManager;  },

    this.dispatcher = dispatcher;  "modules": {

    this.config = config;    "story-lifecycle": {

      "description": "BMAD story lifecycle: backlog → ready-for-dev → in-progress → review → done",

    this.client = new PaperclipClient({      "phases": ["create-story", "dev-story", "code-review", "sprint-planning", "sprint-status"],

      baseUrl: config.paperclip.url,      "transitionRules": {

      apiKey: config.paperclip.apiKey,        "backlog": ["ready-for-dev"],

      orgId: config.paperclip.orgId,        "ready-for-dev": ["in-progress"],

      timeoutMs: config.paperclip.timeoutMs,        "in-progress": ["review"],

    });        "review": ["done", "in-progress"],

        "done": []

    this.reporter = new PaperclipReporter(this.client);      }

  }    },

    "quality-gates": {

  /**      "description": "Adversarial code review with severity-gated merge decisions",

   * Start the Paperclip integration loop.      "severityLevels": ["LOW", "MEDIUM", "HIGH", "CRITICAL"],

   *      "blockingLevels": ["HIGH", "CRITICAL"],

   * This is a long-running async function that blocks until stop() is called      "maxReviewPasses": 3,

   * or maxCycles is reached.      "escalationTarget": "human"

   */    },

  async start(opts: PaperclipLoopOptions = {}): Promise<void> {    "sprint-management": {

    const {      "description": "Sprint tracking and coordination via sprint-status.yaml",

      onEvent,      "sprintDuration": "2 weeks",

      pollIntervalMs = this.config.paperclip.pollIntervalMs,      "statusFile": "_bmad-output/sprint-status.yaml",

      maxCycles,      "artifactDirs": {

      registerAgents = true,        "stories": "_bmad-output/stories/",

    } = opts;        "planning": "_bmad-output/planning-artifacts/",

        "implementation": "_bmad-output/implementation-artifacts/",

    if (this.running) {        "tests": "_bmad-output/test-artifacts/"

      throw new Error("PaperclipLoop is already running");      }

    }    }

  },

    this.running = true;  "settings": {

    this.abortController = new AbortController();    "heartbeatIntervalMs": 5000,

    "maxConcurrentAgents": 2,

    // 1. Register BMAD agents with Paperclip    "reviewPassLimit": 3,

    if (registerAgents) {    "methodology": "bmad-v6",

      await this.registerAllAgents(onEvent);    "defaultModel": "claude-sonnet-4.5",

    }    "qualityGate": "adversarial",

    "paperclip": {

    // 2. Start the Copilot SDK      "mode": "local_trusted",

    if (!this.sessionManager.isReady) {      "url": "http://localhost:3100",

      console.log("[paperclip-loop] Starting Copilot SDK...");      "orgId": "bmad-factory"

      await this.sessionManager.start();    }

      console.log("[paperclip-loop] ✅ SDK ready.");  },

    }  "bootstrapSteps": [

    "Register all BMAD agents with Paperclip",

    // Get agent IDs for polling    "Create sprint-status.yaml with sprint 1",

    const agentIds = allAgents.map((a) => a.name);    "Create docs/ directory for architecture artifacts",

    "Initialize BMAD story templates in stories/",

    onEvent?.({ type: "loop-start", agentCount: agentIds.length });    "Assign CEO goal: 'Define product vision and initial epic'",

    console.log(    "Verify Paperclip connectivity via health check"

      `[paperclip-loop] 🔄 Starting heartbeat loop (poll every ${pollIntervalMs}ms, agents: ${agentIds.join(", ")})`,  ]

    );}


    // 3. Poll loop
    let cycle = 0;
    while (this.running) {
      // Check max cycles
      if (maxCycles !== undefined && cycle >= maxCycles) {
        onEvent?.({ type: "loop-stop", reason: `Reached maxCycles (${maxCycles})` });
        break;
      }

      try {
        // Poll Paperclip for heartbeats
        const pollResult = await this.client.pollHeartbeats(agentIds);

        onEvent?.({ type: "poll", heartbeatCount: pollResult.heartbeats.length });

        // Process each heartbeat
        for (const heartbeat of pollResult.heartbeats) {
          await this.processHeartbeat(heartbeat, onEvent);
        }

        // Respect the server's suggested poll delay
        const delay = pollResult.nextPollAfterMs || pollIntervalMs;
        await this.sleep(delay);
      } catch (err) {
        const errorMsg = err instanceof Error ? err.message : String(err);
        onEvent?.({ type: "poll-error", error: errorMsg });
        console.error(`[paperclip-loop] Poll error: ${errorMsg}`);

        // Back off on errors
        await this.sleep(pollIntervalMs * 2);
      }

      cycle++;
    }

    this.running = false;
    console.log("[paperclip-loop] Loop stopped.");
  }

  /**
   * Stop the Paperclip integration loop gracefully.
   */
  async stop(): Promise<void> {
    console.log("[paperclip-loop] Stopping...");
    this.running = false;
    this.abortController?.abort();

    // Deregister agents (mark offline)
    for (const agent of allAgents) {
      try {
        await this.client.updateAgentStatus(agent.name, "offline");
      } catch {
        // Best-effort
      }
    }

    // Stop the SDK
    await this.sessionManager.stop();
    console.log("[paperclip-loop] Shutdown complete.");
  }

  /**
   * Whether the loop is currently running.
   */
  get isRunning(): boolean {
    return this.running;
  }

  /**
   * Get the Paperclip client for direct API access.
   */
  get paperclipClient(): PaperclipClient {
    return this.client;
  }

  /**
   * Get the reporter for inspecting report history.
   */
  get paperclipReporter(): PaperclipReporter {
    return this.reporter;
  }

  // ── Internal Helpers ──────────────────────────────────────────────────

  /**
   * Register all BMAD agents with Paperclip.
   */
  private async registerAllAgents(
    onEvent?: PaperclipLoopEventHandler,
  ): Promise<void> {
    let registered = 0;
    for (const agent of allAgents) {
      try {
        await this.client.registerAgent({
          id: agent.name,
          name: agent.displayName,
          role: agent.name,
          status: "idle",
          metadata: {
            description: agent.description,
            bmadMethodology: "v6",
          },
        });
        registered++;
        console.log(`[paperclip-loop] Registered agent: ${agent.displayName}`);
      } catch (err) {
        const errorMsg = err instanceof Error ? err.message : String(err);
        console.error(
          `[paperclip-loop] Failed to register ${agent.displayName}: ${errorMsg}`,
        );
      }
    }

    onEvent?.({ type: "agents-registered", count: registered });
  }

  /**
   * Process a single heartbeat: acknowledge, dispatch, report.
   */
  private async processHeartbeat(
    heartbeat: PaperclipHeartbeat,
    onEvent?: PaperclipLoopEventHandler,
  ): Promise<void> {
    const ticketId = heartbeat.ticket?.id;

    try {
      // Acknowledge the heartbeat
      if (ticketId) {
        await this.client.acknowledgeHeartbeat(heartbeat.agentId, ticketId);
      }

      // Mark agent as working
      await this.client.updateAgentStatus(heartbeat.agentId, "working");

      // Process via the heartbeat handler
      const result = await handlePaperclipHeartbeat(
        heartbeat,
        this.dispatcher,
        this.reporter,
      );

      onEvent?.({
        type: "heartbeat-processed",
        agentId: heartbeat.agentId,
        ticketId,
        result,
      });

      // Mark agent as idle when done
      await this.client.updateAgentStatus(heartbeat.agentId, "idle");
    } catch (err) {
      const errorMsg = err instanceof Error ? err.message : String(err);
      onEvent?.({ type: "heartbeat-error", agentId: heartbeat.agentId, error: errorMsg });
      console.error(
        `[paperclip-loop] Heartbeat error for ${heartbeat.agentId}: ${errorMsg}`,
      );

      // Mark agent as stalled
      try {
        await this.client.updateAgentStatus(heartbeat.agentId, "stalled");
      } catch {
        // Best-effort
      }
    }
  }

  /**
   * Abortable sleep — respects the abort controller for clean shutdown.
   */
  private sleep(ms: number): Promise<void> {
    return new Promise((resolve) => {
      const timer = setTimeout(resolve, ms);
      this.abortController?.signal.addEventListener("abort", () => {
        clearTimeout(timer);
        resolve();
      }, { once: true });
    });
  }
}
